{
  "name": "archive-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20 <22"
  },
  "scripts": {
    "prepare": "husky",
    "nx": "nx",
    "lint": "nx run-many --target=lint --all --parallel",
    "typecheck": "nx run-many --target=typecheck --all --parallel",
    "test": "nx run-many --target=test --all --parallel",
    "test:watch": "nx run-many --target=test --all --parallel --watch",
    "build": "nx run-many --target=build --all --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist .nx coverage",
    "security:audit": "npm audit --audit-level=high",
    "security:fund": "npm fund",
    "security:why": "npm ls --depth=0",
    "docker:build": "docker build -t archive-workspace .",
    "docker:up": "docker compose up --build",
    "postinstall": "node -e \"console.log('Installed dependencies for archive-workspace')\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.0.0",
    "@nx/eslint": "^20.0.0",
    "@nx/eslint-plugin": "^20.0.0",
    "@nx/jest": "^20.0.0",
    "@nx/node": "^20.0.0",
    "@nx/next": "^20.0.0",
    "@nx/react": "^20.0.0",
    "@nx/workspace": "^20.0.0",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "lint-staged-lint": "^0.1.3",
    "nx": "^20.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "sort-package-json": "^2.0.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vite": "^5.4.10",
    "wait-on": "^8.0.2",
    "world": "^0.20.0",
    "@types/prettier": "^3.0.9",
    "@types/vitest": "^2.1.3"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}

