# ==============================
# Global ignores for this repo
# Focus: keep the GitHub UI clean (no junk, no local env/OS files)
# ==============================

############################
# OS / Editor / Misc
############################
.DS_Store
.DS_Store?
Thumbs.db
Thumbs.db?
ehthumbs.db
Desktop.ini

# Windows cache files
*.log
*.bak
*.tmp
*.swp
*.swo
*~

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/
*.iml

# Sublime
*.sublime-workspace
*.sublime-project

############################
# Node / Web
############################
node_modules/

# Build output (common)
dist/
build/
out/

# Parcel / Vite / Next / Nuxt / SvelteKit
.cache/
.vite/
.next/
.nuxt/
.svelte-kit/

# Coverage
coverage/
nyc_output/

# Package manager lock / caches
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

############################
# Python
############################
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Poetry
.venv*
poetry.lock

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

############################
# Microsoft Office / Documents / Media junk
############################
*.docx
*.xlsx
*.pptx
*.pdf

############################
# Credentials / Secrets (never commit)
############################
.env
.env.*
*.env

# Common secret/config files
*.pem
*.key
*.crt

# Local-only config
config.local.*
secret.*

############################
# Logs / crash dumps
############################
*.log
*.log.*
*.dmp
core
core.*

############################
# IDE / tooling leftovers
############################
*.pid
*.seed
*.pid.lock

############################
# Images / binaries we might generate locally
############################
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.mp4
*.mov
*.avi
*.mp3
*.wav

############################
# Misc repo hygiene
############################
# ignore editor/session files
*.code-workspace
*.suo
*.user
*.userosscache
*.sln.docstates

# Local thumbnails
*.tmb

# ==============================
# End
# ==============================
